CLookFontApp::CLookFontApp()
{
	m_ProKey1 = "" ;	// LicenceID
	m_ProKey2 = "" ;	// LicenceID
	m_ProKey3 = "" ;	// LicenceID
	m_ProKey4 = "" ;	// Password
	m_ProKey5 = "" ;	// Password
	memset (m_LicenseID, 0, sizeof (char) * 16) ;
	memset (m_LicensePW, 0, sizeof (char) * 16) ;
	m_lfhandle = 0 ;
	m_ProKeyOK = FALSE ;
	m_ActivatOK = FALSE ;
	m_SoftMode = "" ;
}

