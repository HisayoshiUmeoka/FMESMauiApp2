/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU
BEGIN
    POPUP "ファイル(&F)"
    BEGIN
        MENUITEM "印刷（&P）.\tCtrl+P",             ID_FILE_PRINT
        MENUITEM "印刷ﾌﾟﾚﾋﾞｭｰ",                   ID_FILE_PRINT_PREVIEW
        MENUITEM "ﾌﾟﾘﾝﾀの設定(&R)",                ID_FILE_PRINT_SETUP
        MENUITEM SEPARATOR
        MENUITEM "設定(&C)",                      ID_MENU_SETTING
        MENUITEM SEPARATOR
        MENUITEM "アップデートチェック",                  ID_MENU_UPDATE_CHECK
        MENUITEM SEPARATOR
        MENUITEM "ｱﾌﾟﾘｹｰｼｮﾝの終了(&X)",            ID_APP_EXIT
    END
    POPUP "編集(&E)"
    BEGIN
        MENUITEM "コピー(&C)\tCtrl+C",             ID_EDIT_COPY
        MENUITEM "フォント名をコピー(&F)",               ID_MENU_COPYFONTFACE
        MENUITEM "貼り付け(&P)\tCtrl+V",            ID_EDIT_PASTE
        MENUITEM SEPARATOR
        MENUITEM "お気に入りに追加",                    ID_ADD_FAVORITE
        MENUITEM "候補に追加",                       ID_ADD_CANDIDATE
        MENUITEM SEPARATOR
        MENUITEM "プロパティ",                       ID_MENU_PROPATY
        MENUITEM "テスト",                         ID_MENU_TEST
    END
    POPUP "フォント(&C)"
    BEGIN
        MENUITEM "フォントの一時インストール(&T)",           ID_MENU_TMPFONT_INSTALL
        MENUITEM "CD/フォルダ検索 一時インストール",          ID_MENU_TMPFONT_FIND
        MENUITEM SEPARATOR
        MENUITEM "一時フォントのアンイストール(&U)",          ID_MENU_TMPFONT_UNINSTALL
        MENUITEM SEPARATOR
        MENUITEM "一時フォントから本番インストール",            ID_INSTALL_FONT
    END
    POPUP "表示(&V)"
    BEGIN
        MENUITEM "ツールバー(&T)",                   ID_VIEW_TOOLBAR
        MENUITEM "フォント選択バー(&S)",                ID_VIEW_FONTSELECTBAR
        MENUITEM "テキスト入力バー(&C)",                ID_VIEW_TEXTCTRLBAR
        MENUITEM "リスト選択バー(&L)",                 ID_VIEW_TABSELECTBAR
    END
    POPUP "ヘルプ(&H)"
    BEGIN
        MENUITEM "オンラインヘルプﾟ(&H)\tF1",           ID_HELP
        MENUITEM "バージョン情報(&A)...",              ID_APP_ABOUT
        MENUITEM SEPARATOR
        MENUITEM "プラス・エス サイト",                  ID_MENU_PLUSS
        MENUITEM "サポート サイト",                    ID_MENU_SUPPORT
    END
END

IDR_MENU_RCLICK MENU
BEGIN
    POPUP "0"
    BEGIN
        MENUITEM "コピー",                         ID_EDIT_COPY
        MENUITEM "フォント名をコピー",                   ID_MENU_COPYFONTFACE
        MENUITEM SEPARATOR
        MENUITEM "一時フォントから本番インストール",            ID_INSTALL_FONT
        MENUITEM SEPARATOR
        MENUITEM "プロパティ",                       ID_MENU_PROPATY
    END
END


