IDD_DIALOG_SNKEY DIALOG 0, 0, 341, 153
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "プロダクトキー入力"
FONT 9, "ＭＳ ゴシック"
BEGIN
    GROUPBOX        "プロダクトキー",IDC_STATIC,86,34,241,33
