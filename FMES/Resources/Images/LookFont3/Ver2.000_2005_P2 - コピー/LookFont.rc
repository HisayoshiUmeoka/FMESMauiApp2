    EDITTEXT        IDC_EDIT_PROKEY4,236,46,35,14,ES_UPPERCASE | ES_AUTOHSCROLL
    EDITTEXT        IDC_EDIT_PROKEY5,284,46,35,14,ES_UPPERCASE | ES_AUTOHSCROLL
    PUSHBUTTON      "ＰＬＵＳ Ｓ \nサポートサイト",IDC_BUTTON_ACT1,80,120,64,31,BS_MULTILINE
    PUSHBUTTON      "オンライン\n 自動認証",IDC_BUTTON_ACT2,144,120,64,31,BS_MULTILINE
    PUSHBUTTON      "Fax  Email\n 手動認証",IDC_BUTTON_ACT3,208,120,64,31,BS_MULTILINE
    PUSHBUTTON      "閉じる",IDCANCEL,276,120,64,31
    DEFPUSHBUTTON   "OK",IDOK,323,97,17,14,NOT WS_VISIBLE | WS_DISABLED
    CONTROL         IDB_SN_KEY,IDC_STATIC,"Static",SS_BITMAP | SS_REALSIZEIMAGE,0,0,75,153
    LTEXT           "プロダクトキー（半角英数字）を入力し、初回起動時より１０日以内に\n何れかの方法でライセンス認証を完了して下さい。\n※ 期日を過ぎると、認証完了までメイン画面は起動しなくなります。",IDC_STATIC,80,6,257,26
    CTEXT           "－",IDC_STATIC,129,46,9,14,SS_CENTERIMAGE
    CTEXT           "－",IDC_STATIC,177,46,9,14,SS_CENTERIMAGE
    CTEXT           "－",IDC_STATIC,225,46,9,14,SS_CENTERIMAGE
    CTEXT           "－",IDC_STATIC,273,46,9,14,SS_CENTERIMAGE
    LTEXT           "オンライン認証では、プロダクトキーと自動生成したコンピュータＩＤのみを送信致します。 個人情報やプライバシーを侵害する様な情報は一切含まれておりません。",IDC_STATIC,101,72,232,23
    ICON            IDI_ICON_CAUTION,IDC_STATIC,77,73,21,20,SS_CENTERIMAGE
    CONTROL         "",IDC_STATIC,"Static",SS_GRAYRECT | SS_SUNKEN,74,116,267,2
    LTEXT           "認証残日数：",IDC_STATIC_LEAVE1,83,100,48,12,SS_CENTERIMAGE
    RTEXT           "10",IDC_STATIC_LIMITDAYS,133,100,10,12,SS_CENTERIMAGE
    LTEXT           "日",IDC_STATIC_LEAVE2,148,100,10,12,SS_CENTERIMAGE
END

