{
	CString	cs_web	;
	cs_web = theApp.m_appBoot + "\\Ｆａｘライセンス認証コード取得依頼.pdf" ;
	ShellExecute (NULL, "open", cs_web, NULL, NULL, SW_SHOWNORMAL) ;
}

void CUnlockDlg::OnButtonEmail() 
{
	CString	cs_web = "mailto:support@pluss-inc.com?subject=ライセンス認証コード取得依頼［ＬｏｏｋＦｏｎｔ］&body=お名前（全角）：%0D%0Aプロダクトキー（大文字半角英数字）：     -     -     -     -     %0D%0Aユーザーコード１（大文字半角英数字）：%0D%0Aユーザーコード２（大文字半角英数字）：%0D%0AＥｍａｉｌ（半角英数字）：" ;
	ShellExecute (NULL, "open", cs_web, NULL, NULL, SW_SHOWNORMAL) ;
}

void CUnlockDlg::OnChangeEditRegKey1() 
{
	CString cs_Reg1	;
	CString cs_Reg2	;
	GetDlgItemText (IDC_EDIT_REG_KEY_1, cs_Reg1) ;
	GetDlgItemText (IDC_EDIT_REG_KEY_2, cs_Reg2) ;
	cs_Reg1.TrimLeft () ;
	cs_Reg1.TrimRight () ;
	cs_Reg2.TrimLeft () ;
	cs_Reg2.TrimRight () ;
	if (cs_Reg1.GetLength () > 0) {
		if (cs_Reg2.GetLength () > 0) {
			GetDlgItem (IDOK)->EnableWindow (TRUE) ;
		}
	}
}

void CUnlockDlg::OnChangeEditRegKey2() 
{
	CString cs_Reg1	;
	CString cs_Reg2	;
	GetDlgItemText (IDC_EDIT_REG_KEY_1, cs_Reg1) ;
	GetDlgItemText (IDC_EDIT_REG_KEY_2, cs_Reg2) ;
	cs_Reg1.TrimLeft () ;
	cs_Reg1.TrimRight () ;
	cs_Reg2.TrimLeft () ;
	cs_Reg2.TrimRight () ;
	if (cs_Reg1.GetLength () > 0) {
		if (cs_Reg2.GetLength () > 0) {
			GetDlgItem (IDOK)->EnableWindow (TRUE) ;
		}
	}
}
