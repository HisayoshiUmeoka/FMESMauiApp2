CUnlockDlg::CUnlockDlg(CWnd* pParent /*=NULL*/)
	: CDialog(CUnlockDlg::IDD, pParent)
{
	//{{AFX_DATA_INIT(CUnlockDlg)
	m_userCode1String = _T("");
	m_userCode2String = _T("");
	//}}AFX_DATA_INIT
	m_hIcon = AfxGetApp()->LoadIcon(IDI_ICON_LICENCE);
}


void CUnlockDlg::DoDataExchange(CDataExchange* pDX)
{
	CDialog::DoDataExchange(pDX);
	//{{AFX_DATA_MAP(CUnlockDlg)
	DDX_Control(pDX, IDC_EDIT_USER_CODE_1, m_userCode1);
	DDX_Control(pDX, IDC_EDIT_USER_CODE_2, m_userCode2);
	DDX_Control(pDX, IDC_EDIT_REG_KEY_1, m_regKey1);
	DDX_Control(pDX, IDC_EDIT_REG_KEY_2, m_regKey2);
	DDX_Text(pDX, IDC_EDIT_USER_CODE_1, m_userCode1String);
	DDX_Text(pDX, IDC_EDIT_USER_CODE_2, m_userCode2String);
	//}}AFX_DATA_MAP
}


